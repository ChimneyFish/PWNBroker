# Copy this file to .env and fill in what applies. Nothing here is required to
# boot the app — every value has a safe default — but a few are strongly
# recommended for a real deployment (see docs/deployment.md).

# --- Core --------------------------------------------------------------
# Optional. If unset, a random key is generated on first boot and persisted to
# data/secret_key.txt. Only set this explicitly if you're running more than
# one instance against the same database and need them to share a key.
# SECRET_KEY=

# Optional. Defaults to a local SQLite file at data/scanner.db.
# DATABASE_URL=

# "true" (default) requires HTTPS for the session cookie. Only set to "false"
# for local testing without a TLS cert (see run.py's plain-HTTP fallback).
SESSION_COOKIE_SECURE=true

# gunicorn thread count for the single worker process (see docs/deployment.md
# for why this is one worker, not many).
WEB_THREADS=8

# Python logging level for data/logs/app.log — DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# --- Mail (scheduled report delivery) -----------------------------------
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=

# --- Scanner -------------------------------------------------------------
# NMAP_PATH=/usr/bin/nmap
# NVD_API_KEY=

# --- Not env vars, but generated/managed files worth knowing about -------
# data/secret_key.txt        Flask session-signing key (auto-generated)
# data/encryption_key.txt    Fernet key for encrypted DB columns (auto-generated)
# Back BOTH of these up alongside data/scanner.db. Losing encryption_key.txt
# makes every stored API key / SSH credential permanently unrecoverable.
